# Database (Supabase Postgres connection string — direct connection, not pooled,
# for drizzle-kit push; use the pooled/pgbouncer URL for the running app if needed)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App-level secret used to encrypt WhatsApp access tokens / BYO AI keys at rest
SECRET_ENCRYPTION_KEY=

# Meta WhatsApp Cloud API (one Meta App, many connected WABAs per workspace)
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Redis (BullMQ queues — phase 2)
REDIS_URL=redis://localhost:6379

# Payments
PAYSTACK_SECRET_KEY=

# Email
RESEND_API_KEY=

# AI providers — platform-wide fallback keys (workspaces can override with BYO keys)
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

CORS_ORIGIN=http://localhost:3000
PORT=5000
